{
  "name": "azar",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.35",
    "expo-file-system": "~19.0.23",
    "expo-image-picker": "~17.0.11",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas:login": "npx eas-cli login",
    "eas:whoami": "npx eas-cli whoami",
    "eas:configure": "npx eas-cli build:configure",
    "mobile": "node scripts/start-mobile.mjs tunnel",
    "mobile:tunnel": "node scripts/start-mobile.mjs tunnel",
    "mobile:lan": "node scripts/start-mobile.mjs lan",
    "typecheck": "tsc --noEmit",
    "assets": "node scripts/generate-assets.mjs",
    "build:preview": "npx eas-cli build --platform all --profile preview",
    "build:android": "npx eas-cli build --platform android --profile production",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "build:preview:android": "npx eas-cli build --platform android --profile preview",
    "build:preview:ios": "npx eas-cli build --platform ios --profile preview",
    "submit:android": "npx eas-cli submit --platform android --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production"
  },
  "private": true
}
